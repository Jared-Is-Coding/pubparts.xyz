# Where this site lives
SITE_URL=http://localhost:8000/

# Environment (development, production, etc.)
NODE_ENV=development

# Postgres connection for Prisma (see prisma/schema.prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pubparts
    
# Netlify build hook URL for triggering rebuilds when content changes
NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/123456789abcdef12345678